@startuml 04-Modification_Mdp

title Modification du Mot de Passe

actor Attaquant as attacker
participant "Serveur" as server
participant "Victime" as victime
database "rootkey.bin" as rootkey

== Demande de réinitialisation ==
attacker -> server: Demande réinitialisation\ndu mot de passe
activate server

server -> victime: Demande réinitialisation
activate victime

== Génération du nouveau mot de passe ==
victime -> victime: Génère nouveau mot de passe\naléatoire (du dictionnaire)
victime -> victime: Dérive nouvelle MK\navec Argon2

victime -> server: Transmet nouveau mot de passe\net paramètres Argon2

== Rechiffrement de la Root Key ==
server -> server: Dérive nouvelle MK\navec Argon2
server -> server: Récupère RK via\nKyber désencapsulation
server -> server: Chiffre RK\navec nouvelle MK\n(AES-GCM 256 bits)

server -> victime: Envoie nouvelle RK chiffrée\n(ciphertext, nonce, tag)

== Mise à jour sur le victime ==
victime -> rootkey: Remplace ancienne RK chiffrée\npar nouvelle (ciphertext, nonce, tag)
activate rootkey
rootkey --> victime: OK
deactivate rootkey

victime --> server: Mot de passe modifié
deactivate victime

server --> attacker: Mot de passe réinitialisé
deactivate server

@enduml
